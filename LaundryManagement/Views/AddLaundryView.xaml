<UserControl x:Class="LaundryManagement.Views.AddLaundryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="Transparent">

        <Border Background="White"
                Width="450"
                Padding="30"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Add Laundry Order"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0 0 0 20"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Order ID"/>
                <TextBox Height="35"
                         Margin="0 5 0 15"
                         Text="{Binding OrderId}" />

                <TextBlock Text="Customer Name"/>
                <TextBox Height="35"
                         Margin="0 5 0 15"
                         Text="{Binding CustomerName}" />

                <TextBlock Text="Contact Number"/>
                <TextBox Height="35"
                         Margin="0 5 0 15"
                         Text="{Binding ContactNumber}" />

                <TextBlock Text="Service Type"/>
                <TextBox Height="35"
                         Margin="0 5 0 15"
                         Text="{Binding ServiceType}" />

                <TextBlock Text="Weight (kg)"/>
                <TextBox Height="35"
                         Margin="0 5 0 15"
                         Text="{Binding WeightInKg}" />

                <TextBlock Text="Total Price"/>
                <TextBox Height="35"
                         Margin="0 5 0 20"
                         Text="{Binding TotalPrice}" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Content="Save"
                            Width="120"
                            Height="40"
                            Background="#4CAF50"
                            Foreground="White"
                            Margin="0 0 10 0"
                            Command="{Binding SaveCommand}" />

                    <Button Content="Back"
                            Width="120"
                            Height="40"
                            Background="#9E9E9E"
                            Foreground="White"
                            Command="{Binding BackCommand}" />
                </StackPanel>

            </StackPanel>

        </Border>
    </Grid>
</UserControl>